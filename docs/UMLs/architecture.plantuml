@startuml
title Layered Architecture - Personal Budgeting System

' =========================
' PRESENTATION LAYER
' =========================
package "Presentation Layer (UI)" {

  component "Mobile App (Android / iOS)" as MobileUI
  component "Web Application" as WebUI

  component "Dashboard UI" as DashUI
  component "Transactions UI" as TransUI
  component "Budget UI" as BudgUI
  component "Reports UI" as RepUI
  component "Goals UI" as GoalUI
  component "Notifications UI" as NotifUI

  MobileUI --> DashUI
  MobileUI --> TransUI
  MobileUI --> BudgUI
  MobileUI --> RepUI
  MobileUI --> GoalUI
  MobileUI --> NotifUI

  WebUI --> DashUI
  WebUI --> TransUI
  WebUI --> BudgUI
  WebUI --> RepUI
  WebUI --> GoalUI
  WebUI --> NotifUI
}

' =========================
' APPLICATION / BUSINESS LAYER
' =========================
package "Application Layer (Business Logic)" {

  component "Authentication Module" as AuthMod
  component "User Management Module" as UserMod
  component "Transaction Management Module" as TransMod
  component "Budget Management Module" as BudgMod
  component "Category Management Module" as CatMod
  component "Goal Management Module" as GoalMod
  component "Report Module" as RepMod
  component "Notification Module" as NotifMod
}

' =========================
' DATA LAYER
' =========================
package "Data Layer" {

  database "Main Database\n(AES-256 Encrypted)" as DB

  component "User Repository" as UserRepo
  component "Transaction Repository" as TransRepo
  component "Budget Repository" as BudgRepo
  component "Category Repository" as CatRepo
  component "Goal Repository" as GoalRepo
  component "Notification Repository" as NotifRepo
}

' =========================
' EXTERNAL SYSTEMS
' =========================
package "External Systems" {
  component "Bank API (OAuth2)" as BankAPI
  component "E-Wallet API" as WalletAPI
}

' =========================
' CONNECTIONS
' =========================

' UI -> Business
MobileUI --> AuthMod
WebUI --> AuthMod

DashUI --> TransMod
TransUI --> TransMod
BudgUI --> BudgMod
RepUI --> RepMod
GoalUI --> GoalMod
NotifUI --> NotifMod

' Business -> Data
UserMod --> UserRepo
TransMod --> TransRepo
BudgMod --> BudgRepo
CatMod --> CatRepo
GoalMod --> GoalRepo
NotifMod --> NotifRepo

' Repositories -> Database
UserRepo --> DB
TransRepo --> DB
BudgRepo --> DB
CatRepo --> DB
GoalRepo --> DB
NotifRepo --> DB

' External Integration
TransMod --> BankAPI
TransMod --> WalletAPI

@enduml
