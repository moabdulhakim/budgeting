@startuml
title Personal Budgeting System - Class Diagram

'======================
' USERS
'======================

class User {
  - userId: int
  - name: String
  - email: String
  - password: String
  - balance: double

  + signUp()
  + login()
  + updateProfile()
}

class Admin {
  + createDefaultCategory()
  + manageUserAccount()
  + generateSystemReport()
}

User <|-- Admin


'======================
' TRANSACTIONS
'======================

abstract class Transaction {
  - transactionId: int
  - amount: double
  - date: Date
  - note: String

  + getDetails()
}

class Income {
  - source: String

  + addIncome()
}

class Expense {
  - categoryId: int

  + addExpense()
}

Transaction <|-- Income
Transaction <|-- Expense

User "1" o-- "0..*" Transaction : records


'======================
' CATEGORY
'======================

class Category {
  - categoryId: int
  - name: String
  - type: String

  + createCategory()
  + editCategory()
  + deleteCategory()
}

User "1" o-- "0..*" Category : defines
Category "1" <-- "0..*" Expense : used in


'======================
' BUDGET
'======================

class Budget {
  - budgetId: int
  - month: String
  - totalLimit: double

  + createBudget()
  + updateBudget()
  + calculateRemaining()
  + checkBudgetStatus()
}

User "1" o-- "0..*" Budget
Budget "1" o-- "1..*" Category : limits per category


'======================
' GOALS
'======================

class Goal {
  - goalId: int
  - targetAmount: double
  - currentAmount: double
  - progress: double

  + setGoal()
  + updateProgress()
}

User "1" o-- "0..*" Goal


'======================
' REPORTS & DASHBOARD
'======================

class Report {
  - reportId: int
  - month: String

  + generateReport()
  + showSummary()
}

class Dashboard {
  + viewTotalIncome()
  + viewTotalExpense()
  + viewBalance()
  + viewRecentTransactions()
}

User ..> Dashboard
User ..> Report


'======================
' SERVICES (BUSINESS LOGIC LAYER)
'======================

class AuthService {
  + signUp(name, email, password)
  + login(email, password)
  + validateCredentials()
}

class TransactionService {
  + addIncome()
  + addExpense()
  + getTransactions()
}

class CategoryService {
  + createCategory()
  + editCategory()
  + deleteCategory()
}

class BudgetService {
  + createBudget()
  + calculateRemainingBudget()
  + checkBudgetLimit()
  + trackBudgetUsage()
}

class ReportService {
  + generateMonthlyReport()
}

class NotificationService {
  + sendBudgetAlert()
}


'======================
' DATABASE
'======================

class Database {
  + save()
  + update()
  + delete()
  + fetch()
}

AuthService --> Database
TransactionService --> Database
CategoryService --> Database
BudgetService --> Database
ReportService --> Database


'======================
' UI LAYER
'======================

class UI {
  + showSignUp()
  + showLogin()
  + showDashboard()
  + showAddIncomeForm()
  + showAddExpenseForm()
  + showBudgetScreen()
  + showCategoryScreen()  
  + submit()             
  + login()              
}

UI --> AuthService
UI --> TransactionService
UI --> BudgetService
UI --> CategoryService
UI --> ReportService


'======================
' RELATIONSHIPS (KEY LOGIC LINKS)
'======================

BudgetService --> Budget
BudgetService --> Expense
TransactionService --> Income
TransactionService --> Expense
BudgetService --> NotificationService

@enduml
