@startuml
!pragma plantuml_limit_size 8192
title Personal Budgeting System - Class Diagram
skinparam classAttributeIconSize 0
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontSize 12
skinparam ArrowColor #555555
skinparam ClassBorderColor #333333

' ===================== View Layer (accounts app) =====================
package "accounts (Auth Views)" as LayerAuth {
    class signup_view {
        + GET(): render signup page
        + POST(username, password, name): create User
    }
    class login_view {
        + GET(): render login page
        + POST(username, password): authenticate
    }
    class logout_view {
        + POST(): end session
    }
}

' ===================== View Layer (dashboard app) =====================
package "dashboard (Dashboard Views)" as LayerDashboard {
    class getDashboard {
        + GET(): aggregate stats & render
        - detect_top_subscription(): dict|None
    }
    class getNotifications {
        + GET(): list user notifications
    }
}

' ===================== View Layer (finances app) =====================
package "finances (Finance Views)" as LayerFinances {
    class CategoryViews {
        + add_category(name, budget)
        + delete_category(category_id)
    }
    class BudgetViews {
        + set_budget(category_id, amount, start_date, end_date)
        + get_budget_page()
    }
    class TransactionViews {
        + add_transaction(name, amount, currency, type, ...)
        + update_transaction(transaction_id, ...)
        + delete_transaction(transaction_id)
        + get_transactions_page(filter)
        + voice_transaction(transcript): Transaction
    }
    class ReportViews {
        + get_reports_page(period)
        + dashboard_data()
    }
    class ChatbotViews {
        + chatbot_reply(message): JsonResponse
    }
    class ReceiptOCRViews {
        + upload_receipt(image): redirect
        + confirm_receipt(scan_id): Transaction
        - _ocr_parse(image_file): dict
    }
    class CurrencyViews {
        + get_fx_rates(): JsonResponse
    }
}

' ===================== View Layer (goals app) =====================
package "goals (Goal Views)" as LayerGoals {
    class GoalFunctionViews {
        + getGoals()
        + getGoal(goalId)
        + add_goal(name, target, saved, image)
        + delete_goal(goal_id)
        + depositGoalAmount(goalId, amount)
    }
    class GoalCreateView <<CreateView>> {
        + model: Goal
        + fields: list
        + template_name: string
        + success_url: string
        + form_valid(form)
    }
    class GoalUpdateView <<UpdateView>> {
        + model: Goal
        + fields: list
        + template_name: string
        + success_url: string
        + slug_field: string
        + slug_url_kwarg: string
        + form_valid(form)
    }
}

' ===================== Service Layer =====================
package "Services" as LayerServices {
    class CurrencyService {
        - BASE_URL: string
        - CACHE_KEY: string
        - CACHE_TTL: int = 3600
        - SUPPORTED_CURRENCIES: dict
        + get_rates(): dict
        + to_usd(amount: Decimal, currency: str): tuple
        - _fetch_rates(): dict
    }
}

' ===================== Models (Entity Layer) =====================
package "Models (Entity Layer)" as LayerModel {

    class User <<Django Built-in>> {
        - id: int
        - username: string
        - email: string
        - password: string
        - first_name: string
        - is_staff: bool
    }

    class Category {
        - id: int
        - name: string
        - budgeted: Decimal
        - spent: Decimal
        - icon: string
        - is_custom: bool
    }

    class Budget {
        - id: int
        - amount: Decimal
        - start_date: Date
        - end_date: Date
        - alert_threshold: int
    }

    class Transaction {
        - id: int
        - name: string
        - amount: Decimal
        - type: string <<income|expense>>
        - date: DateTime
        - payment_method: string
        - description: string
        - is_upcoming: bool
        - due_date: Date
    }

    class Notification {
        - id: int
        - message: string
        - reference_key: string
        - alert_type: string <<general|budget|upcoming>>
        - is_read: bool
        - created_at: DateTime
    }

    class Goal {
        - id: UUID
        - name: string
        - description: string
        - dueDate: Date
        - target: Decimal
        - current: Decimal
        - image: ImageField
        - createdAt: DateTime
        - updatedAt: DateTime
        + getProgress(): float
    }

    class ReceiptScan {
        - id: int
        - image: ImageField
        - raw_text: string
        - merchant: string
        - total: Decimal
        - receipt_date: Date
        - status: string <<pending|done|failed>>
        - created_at: DateTime
    }

    class checkBudgetAmount <<Signal: post_save>> {
        + triggered on: Transaction save
        + reads: Budget
        + creates: Notification
    }
}

' ===================== Layout hints =====================
LayerAuth -[hidden]right-> LayerDashboard
LayerDashboard -[hidden]right-> LayerFinances
LayerFinances -[hidden]right-> LayerGoals
LayerAuth -[hidden]down-> LayerModel
LayerDashboard -[hidden]down-> LayerModel
LayerFinances -[hidden]down-> LayerModel
LayerGoals -[hidden]down-> LayerModel
LayerServices -[hidden]down-> LayerModel

' ===================== View → Model Dependencies =====================

' Auth
signup_view ..> User
login_view ..> User

' Dashboard
getDashboard ..> Transaction
getDashboard ..> Category
getDashboard ..> Notification
getDashboard ..> Goal

getNotifications ..> Notification

' Finance
CategoryViews ..> Category
CategoryViews ..> Notification
BudgetViews ..> Budget
BudgetViews ..> Category
BudgetViews ..> Transaction
TransactionViews ..> Transaction
TransactionViews ..> Category
TransactionViews ..> Notification
TransactionViews ..> CurrencyService
ReportViews ..> Transaction
ReportViews ..> Category
ReportViews ..> Goal
ChatbotViews ..> Transaction
ChatbotViews ..> Category
ChatbotViews ..> Goal
ReceiptOCRViews ..> ReceiptScan
ReceiptOCRViews ..> Transaction
ReceiptOCRViews ..> Category
CurrencyViews ..> CurrencyService

' Goals
GoalFunctionViews ..> Goal
GoalFunctionViews ..> Notification
GoalCreateView ..> Goal
GoalUpdateView ..> Goal

' ===================== Signal =====================
checkBudgetAmount ..> Transaction : listens (post_save)
checkBudgetAmount ..> Budget : reads
checkBudgetAmount ..> Notification : creates

' ===================== Model FK Associations =====================
User "1" o-- "0..*" Transaction : owns
User "1" o-- "0..*" Category : owns
User "1" o-- "0..*" Budget : owns
User "1" o-- "0..*" Goal : authors
User "1" o-- "0..*" Notification : receives
User "1" o-- "0..*" ReceiptScan : owns

Transaction "0..*" --> "1" Category : categorized by
Budget "0..*" --> "1" Category : limits
ReceiptScan "0..1" --> "0..1" Transaction : creates

@enduml
